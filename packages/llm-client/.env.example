# LLM Client Package - Environment Variables
# Copy this file to .env and fill in your values

# for the image analysis tests we need the GH Token to load the test files
GITHUB_TOKEN=


# Encryption key for test connections to providers
ENCRYPTION_KEY=

# Ollama instance URL
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=


# Chat completion model (e.g., llama3.2, mistral, phi3)
MODEL_NAME_CHAT=llama3.2
# Embedding model (e.g., nomic-embed-text, mxbai-embed-large)
MODEL_NAME_EMBEDDING=nomic-embed-text
# Vision-language model for image processing (e.g., llama3.2-vision, llava)
MODEL_NAME_VL=llama3.2-vision

# =============================================================================
# OpenAI Configuration (Optional - for integration tests)
# =============================================================================

# OpenAI API key (required for OpenAI tests)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
