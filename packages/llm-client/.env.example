# LLM Client Package - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Ollama Configuration (Optional - for integration tests)
# =============================================================================

# Ollama instance URL
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Ollama API key (optional - only needed if your Ollama instance requires authentication)
OLLAMA_API_KEY=

# Model names for testing different capabilities
# These should match models available in your Ollama instance

# Chat completion model (e.g., llama3.2, mistral, phi3)
MODEL_NAME_CHAT=llama3.2

# Embedding model (e.g., nomic-embed-text, mxbai-embed-large)
MODEL_NAME_EMBEDDING=nomic-embed-text

# Vision-language model for image processing (e.g., llama3.2-vision, llava)
MODEL_NAME_VL=llama3.2-vision

# =============================================================================
# OpenAI Configuration (Optional - for integration tests)
# =============================================================================

# OpenAI API key (required for OpenAI tests)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI base URL (optional - defaults to https://api.openai.com/v1)
# Use this if you're using a custom OpenAI-compatible endpoint
OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Azure OpenAI Configuration (Optional - for Azure compatibility tests)
# =============================================================================

# Azure OpenAI endpoint URL
# Example: https://your-resource-name.openai.azure.com/openai/deployments/your-deployment-name
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI API key
AZURE_OPENAI_API_KEY=

# =============================================================================
# Notes
# =============================================================================
#
# 1. Integration tests are automatically skipped if required variables are not set
# 2. For local development, you only need to configure the providers you're using
# 3. All environment variables are optional - tests will skip gracefully if not configured
# 4. Make sure to run `pnpm install` before running tests
#
# Running tests:
#   pnpm test              # Run all tests
#   pnpm test:watch        # Run tests in watch mode
#   pnpm typecheck         # Run TypeScript type checking
#   pnpm lint              # Run ESLint
