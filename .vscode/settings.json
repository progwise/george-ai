{
  "prisma.pinToPrisma6": false,
  "vitest.maximumConfigs": 40,
  "editor.hover.above": false,
  "editor.hover.delay": 800,
  "editor.hover.sticky": true,
  "js/ts.updateImportsOnFileMove.enabled": "never",
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/coverage/**": true
  }
}
