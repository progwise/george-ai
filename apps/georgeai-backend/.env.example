# Logging Configuration
# LOG_LEVEL: Controls logging verbosity (ERROR, WARN, INFO, DEBUG)
# Default: INFO
# Use DEBUG for detailed troubleshooting, ERROR for production
LOG_LEVEL=INFO

# Main George-Ai Metadata Source
DATABASE_URL="postgresql://chatweb:password@gai-chatweb-db:5432/chatweb?schema=public"

# The main storage configuration for workspaces, assistant and user files
STORAGE_PATH_WORKSPACES=/workspaces/george-ai/.storage/workspace-storage
STORAGE_PATH_WORKSPACES_BACKUP=/workspaces/george-ai/.storage/workspace-storage-backup
STORAGE_PATH_ASSISTANTS=/workspaces/george-ai/.storage/assistant-storage
STORAGE_PATH_USERS=/workspaces/george-ai/.storage/user-storage
STORAGE_PATH_CREDENTIALS=/workspaces/george-ai/.storage/credential-storage
STORAGE_PATH_LEGACY_LIBRARIES=/workspaces/george-ai/.uploads

# Encryption key for sensitive connector credentials (required for automations)
# Must be 64 hex characters (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Accessing the GraphQL API of George-Ai if no other Auth is available, mainly for
# testing purpose
GRAPHQL_API_KEY=TestKey

# Crawler Services Configuration
SMB_CRAWLER_URL=http://localhost:3006

TYPESENSE_API_HOST="gai-typesense"
TYPESENSE_API_PORT="8108"
TYPESENSE_API_PROTOCOL="http"
TYPESENSE_API_KEY="xyz"
UPLOADS_PATH=./.uploads

# SMTP Email Configuration (optional - for notifications and contact forms)
# These fields are OPTIONAL - only configure if you want email functionality
# If not configured, features requiring email (notifications, contact forms) will be disabled
# The example values below show the format - replace with your actual SMTP server details
SMTP_HOSTNAME=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@george-ai.net
SMTP_TEST_RECIPIENT=your-email@example.com  # Required for mailer integration tests

BACKEND_PUBLIC_URL=http://localhost:3003
PUBLIC_APP_URL=http://localhost:3001

# For enabling/syncing OPENAI API credentials
OPENAI_API_KEY=sk-proj-

# The OLLAMA API key is optional for local OLLAMA deployments without authentication
# Some Ollama instances may not support API keys depending on version/configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# OLLAMA VRAM Configuration (GB) - defaults to 16GB if not set
OLLAMA_VRAM_GB=32

# Multiple OLLAMA instances (optional)
OLLAMA_BASE_URL_1=http://host.docker.internal:11434
OLLAMA_API_KEY_1=
OLLAMA_VRAM_GB_1=64

OLLAMA_BASE_URL_2=https://ollama.example.com:11434
OLLAMA_API_KEY_2=your-api-key-here
OLLAMA_VRAM_GB_2=128

# Auto Start Workers
AUTOSTART_ENRICHMENT_WORKER=false
AUTOSTART_CONTENT_PROCESSING_WORKER=false